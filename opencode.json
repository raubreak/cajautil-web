{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-scheduler"],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--isolated",
        "--no-usage-statistics"
      ],
      "enabled": true
    },
    "magic": {
      "type": "local",
      "command": ["npx", "-y", "@21st-dev/magic@latest"],
      "enabled": true,
      "environment": {
        "API_KEY": "{file:.opencode/secrets/21st-dev-magic-api-key}"
      }
    }
  }
}
